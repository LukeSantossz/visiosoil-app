<?xml version="1.0" encoding="utf-8"?>
<!--
  Excludes all app data from cloud backup and device-to-device transfer on
  Android 12+ (API 31+). The cleartext soil-records database and the captured
  soil_images/ originals are confidential field data (#111); on API 31+
  allowBackup="false" no longer covers device-to-device transfer, so every data
  domain is excluded from both paths here. The database and sharedpref domains
  are flat (no subdirectories), so they are excluded whole, without a path.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="/" />
        <exclude domain="file" path="/" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" path="/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="/" />
        <exclude domain="file" path="/" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" path="/" />
    </device-transfer>
</data-extraction-rules>
